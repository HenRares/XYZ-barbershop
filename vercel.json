{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "framework": null,
    "buildCommand": "npm run build",
    "outputDirectory": "public",
    "functions": {
        "api/*.php": {
            "runtime": "vercel-php@0.9.0",
            "maxDuration": 60
        }
    },
    "routes": [
        {
            "src": "/build/(.*)",
            "dest": "/api/assets.php?file=build/$1"
        },
        {
            "src": "/(favicon\\.ico|robots\\.txt)",
            "dest": "/api/assets.php?file=$1"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}